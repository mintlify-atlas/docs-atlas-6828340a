  "keyFeatures": [
    "Zero-trust Docker sandbox execution",
    "Shadow credential injection - real keys never enter the container",
    "Parallel adversarial test generation",
    "Multi-agent support (Claude Code, Codex, Aider, Kiro)",
    "Interactive shell with persistent sessions",
    "HTTP/HTTPS credential-swap proxy with MITM",
    "AWS integration (S3 snapshots, CloudWatch, Secrets Manager, Bedrock Guardrails)",
    "Credential and dangerous operation linting",
    "Project snapshot management with rsync or S3"
  ],
  "publicApiSurface": [
    "ftl setup - Pull sandbox image, choose agent + tester, save API key",
    "ftl init - Create .ftlconfig in current project",
    "ftl code <task> - Run task, review, merge/reject",
    "ftl - Interactive shell",
    "ftl config --aws - Provision AWS resources and write config",
    "ftl snapshots - List and manage project snapshots",
    "ftl auth <KEY> <VALUE> - Save credential to ~/.ftl/credentials",
    "ftl logs - Show session audit log"
  ]
